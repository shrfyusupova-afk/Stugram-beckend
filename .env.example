NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://<username>:<password>@stugram.hhsjgwp.mongodb.net/stugram?retryWrites=true&w=majority&appName=Stugram
ENABLE_BOOTSTRAP_USER=false
BOOTSTRAP_USER_IDENTITY=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_USER_USERNAME=
BOOTSTRAP_USER_FULL_NAME=
BOOTSTRAP_USER_ROLE=user
