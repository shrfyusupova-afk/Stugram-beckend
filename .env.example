REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_PREFIX=stugram
REDIS_REQUIRED=false
QUEUE_ENABLED=false
WORKER_REQUIRED=false
RECOMMENDATION_WORKER_ENABLED=false
RECOMMENDATION_MODE=db-direct
CACHE_MODE=redis-optional
ENABLE_MAINTENANCE_CLEANUP_SCHEDULER=false
MAINTENANCE_CLEANUP_INTERVAL_MINUTES=60
EXPIRED_STORY_RETENTION_HOURS=6
INACTIVE_PUSH_TOKEN_RETENTION_DAYS=30
REVOKED_SESSION_RETENTION_DAYS=90
PASSWORD_RESET_RETENTION_DAYS=7
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
