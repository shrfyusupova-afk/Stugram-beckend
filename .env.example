OTP_EXPIRES_MINUTES=10
OTP_PROVIDER=mock
SMS_PROVIDER=twilio
EMAIL_PROVIDER=resend
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_WINDOW=5
OTP_SEND_WINDOW_MINUTES=60
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=
BREVO_SMS_SENDER=
PASSWORD_RESET_BASE_URL=
APP_DEEP_LINK_RESET_URL=
REQUEST_SLOW_MS=800
MONGO_SLOW_QUERY_MS=250
MONGO_QUERY_DEBUG=false
ALLOW_MEMORY_DB_FALLBACK=false
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=15000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_FORCE_IPV4=true
MONGO_STARTUP_DIAGNOSTICS=true
MONGO_DNS_SERVERS=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
